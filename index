<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>코드네임스 - Oncuvate</title>
<style>
@font-face{font-family:'NexonMaplestory';src:url('https://cdn.jsdelivr.net/gh/fonts-archive/Maplestory/Maplestory-Bold.woff2') format('woff2'),url('https://cdn.jsdelivr.net/gh/projectnoonnu/noonfonts_20-04@2.1/MaplestoryOTFBold.woff') format('woff');font-weight:700;font-display:swap;}
*{margin:0;padding:0;box-sizing:border-box;}
body{background:#000;width:1280px;height:720px;max-width:100vw;max-height:100vh;overflow:hidden;margin:0 auto;font-family:'Malgun Gothic','Apple SD Gothic Neo',Arial,sans-serif;color:#fff;}

.header{height:80px;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:0;}
.header-title{font-size:60px;font-weight:normal;color:#5CE1E6;letter-spacing:0.04em;display:flex;align-items:center;gap:14px;font-family:'NexonMaplestory',sans-serif;}
.header-title img{height:60px;}

.screen{display:none;position:absolute;top:80px;left:0;right:0;bottom:0;padding:16px 32px;overflow:hidden;}
.screen.active{display:flex;flex-direction:column;}
#home.active{align-items:center;justify-content:center;overflow-y:auto;}
#maker.active{overflow-y:auto;}
#saved.active{overflow-y:auto;}

#home{align-items:center;justify-content:center;gap:40px;}
.home-buttons{display:flex;gap:24px;flex-wrap:wrap;justify-content:center;align-items:center;}
.home-btn{background:rgba(217,238,239,0.06);border:2px solid #5CE1E6;border-radius:20px;padding:32px 48px;cursor:pointer;transition:all 0.2s;text-align:center;min-width:200px;}
.home-btn:hover{background:rgba(92,225,230,0.12);transform:translateY(-4px);}
.home-btn .btn-icon{margin-bottom:12px;}
.home-btn .btn-label{font-size:18px;font-weight:600;color:#5CE1E6;}
.home-btn .btn-desc{font-size:13px;color:rgba(255,255,255,0.45);margin-top:6px;line-height:1.6;}

.section-title{font-size:20px;font-weight:700;color:#5CE1E6;}
.card-box{background:rgba(217,238,239,0.06);border:1px solid rgba(92,225,230,0.2);border-radius:14px;padding:14px 18px;}
.lbl{font-size:11px;color:rgba(255,255,255,0.45);margin-bottom:5px;font-weight:600;letter-spacing:0.06em;text-transform:uppercase;}
input[type=text],select,textarea{background:rgba(255,255,255,0.06);border:1px solid rgba(92,225,230,0.3);border-radius:9px;padding:8px 12px;font-size:14px;color:#fff;outline:none;font-family:inherit;transition:border-color 0.2s;}
input:focus,select:focus,textarea:focus{border-color:#5CE1E6;}
select option{background:#111;}
textarea{resize:none;width:100%;}
.back-btn{background:transparent;color:rgba(255,255,255,0.45);border:1px solid rgba(255,255,255,0.18);border-radius:8px;padding:6px 14px;font-size:13px;cursor:pointer;transition:all 0.2s;}
.back-btn:hover{color:#fff;border-color:rgba(255,255,255,0.45);}
.pri-btn{background:#5CE1E6;color:#000;border:none;border-radius:10px;padding:10px 24px;font-size:14px;font-weight:700;cursor:pointer;transition:opacity 0.2s;}
.pri-btn:hover{opacity:0.85;}
.sec-btn{background:transparent;color:#5CE1E6;border:2px solid #5CE1E6;border-radius:10px;padding:8px 20px;font-size:13px;font-weight:600;cursor:pointer;transition:all 0.2s;}
.sec-btn:hover{background:rgba(92,225,230,0.1);}
.tag{background:rgba(92,225,230,0.1);border:1px solid rgba(92,225,230,0.35);border-radius:6px;padding:3px 9px;font-size:12px;display:inline-flex;align-items:center;gap:5px;margin:2px;}
.tag .rm{cursor:pointer;color:#f87171;font-size:13px;line-height:1;}
.rtag{background:rgba(248,71,71,0.12);border-color:rgba(248,71,71,0.4);color:#f87171;}
.ntag{background:rgba(100,100,100,0.15);border-color:rgba(150,150,150,0.3);color:#aaa;}
.cnt{display:inline-block;background:rgba(92,225,230,0.2);border-radius:5px;padding:1px 7px;font-size:11px;color:#5CE1E6;margin-left:6px;}
.maker-row{display:grid;gap:12px;}
.row2{grid-template-columns:1fr 1fr;}
.row3{grid-template-columns:1fr 1fr 1fr;}
.tags-wrap{display:flex;flex-wrap:wrap;margin-top:6px;max-height:52px;overflow-y:auto;}
.action-row{display:flex;gap:10px;align-items:center;flex-wrap:wrap;}

#play{gap:0;padding:0;}
.play-wrap{display:flex;height:100%;}
.play-main{flex:1;display:flex;flex-direction:column;padding:14px 18px;gap:8px;overflow:hidden;}
.play-side{width:270px;background:rgba(217,238,239,0.05);border-left:1px solid rgba(92,225,230,0.18);padding:12px 14px;overflow-y:auto;display:flex;flex-direction:column;gap:8px;}

.cards-area{flex:1;display:flex;align-items:center;justify-content:center;}
.card-grid{display:grid;gap:7px;}
.gc{border-radius:10px;cursor:pointer;display:flex;align-items:center;justify-content:center;font-weight:700;border:2px solid rgba(255,255,255,0.12);background:rgba(35,35,55,0.95);color:#fff;transition:all 0.15s;user-select:none;text-align:center;padding:4px 6px;}
.gc:hover{transform:scale(1.04);border-color:rgba(92,225,230,0.6);}
.gc.r-blue{background:#1a5fa8;border-color:#4a9eff;}
.gc.r-red{background:#a81a1a;border-color:#ff4a4a;}
.gc.r-neutral{background:#444;border-color:#777;color:#bbb;}
.gc.r-bomb{background:#111;border-color:#ff0;color:#ff0;}

.score-row{display:flex;gap:8px;}
.sbox{flex:1;border-radius:9px;padding:7px;text-align:center;}
.sbox.b{background:rgba(26,95,168,0.25);border:1px solid #4a9eff;}
.sbox.r{background:rgba(168,26,26,0.25);border:1px solid #ff4a4a;}
.snum{font-size:22px;font-weight:700;}
.slbl{font-size:11px;color:rgba(255,255,255,0.38);}
.b .snum{color:#4a9eff;} .r .snum{color:#ff4a4a;}

.clue-panel{background:rgba(217,238,239,0.07);border:1px solid rgba(92,225,230,0.2);border-radius:11px;padding:10px 12px;flex:1;display:flex;flex-direction:column;gap:6px;}
.clue-panel-hd{font-size:13px;color:#401F71;background:#D9EEEF;border-radius:7px;padding:4px 10px;text-align:center;font-weight:700;}
.open-btn{background:#5CE1E6;color:#000;border:none;border-radius:9px;padding:8px;font-size:13px;font-weight:700;cursor:pointer;width:100%;transition:opacity 0.2s;}
.open-btn:hover{opacity:0.85;}
.open-btn:disabled{opacity:0.3;cursor:not-allowed;}
.clue-list{flex:1;overflow-y:auto;}
.ci{background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.1);border-radius:7px;padding:7px 9px;margin-bottom:5px;transition:all 0.2s;}
.ci.opened{background:rgba(92,225,230,0.12);border-color:#5CE1E6;}
.ci .cw{font-size:14px;font-weight:700;color:#5CE1E6;}
.ci .cn{font-size:11px;color:rgba(255,255,255,0.35);margin-top:1px;}
.ci.locked .cw{color:rgba(255,255,255,0.25);filter:blur(5px);}
.ci.locked .cn{color:rgba(255,255,255,0.2);}

.msg-box{background:rgba(92,225,230,0.08);border:1px solid rgba(92,225,230,0.22);border-radius:8px;padding:7px 12px;font-size:13px;color:#5CE1E6;text-align:center;}

#complete{align-items:center;justify-content:center;gap:20px;text-align:center;}
#saved{gap:14px;}
.saved-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:12px;}
.sc{background:rgba(217,238,239,0.06);border:1px solid rgba(92,225,230,0.22);border-radius:13px;padding:14px;cursor:pointer;transition:all 0.2s;}
.sc:hover{transform:translateY(-3px);border-color:#5CE1E6;}
.sc-title{font-size:14px;font-weight:700;color:#5CE1E6;margin-bottom:4px;}
.sc-meta{font-size:12px;color:rgba(255,255,255,0.38);}
.empty{color:rgba(255,255,255,0.3);text-align:center;padding:50px;font-size:15px;}
</style>
</head>
<body>

<div class="header" style="padding-top:60px;">
  <div class="header-title">
    <img src="data:image/png;base64," alt="">코드네임스
  </div>
</div>

<!-- 홈 -->
<div class="screen active" id="home">
  <div class="home-buttons">
    <div class="home-btn" onclick="showScreen('maker')">
      <div class="btn-icon"><img src="data:image/png;base64," style="width:90px;height:auto;" alt="NEW!"></div>
      <div class="btn-label">게임 만들기</div>
      <div class="btn-desc">제시어·단어·함정카드를<br>설정하고 게임을 만드세요</div>
    </div>
    <div class="home-btn" onclick="showScreen('saved')">
      <div class="btn-icon"><img src="data:image/png;base64," style="width:80px;height:auto;" alt="폴더"></div>
      <div class="btn-label">저장된 게임</div>
      <div class="btn-desc">이전에 만든 게임을<br>불러와 플레이하세요</div>
    </div>
  </div>
  <div style="display:flex;justify-content:center;">
    <img src="data:image/png;base64," style="width:360px;max-width:90%;height:auto;object-fit:contain;" alt="Oncuvate">
  </div>
<!-- 게임 만들기 -->
<div class="screen" id="maker">
  <div style="display:flex;gap:10px;align-items:center;margin-bottom:10px;">
    <button class="back-btn" onclick="showScreen('home')">← 홈</button>
    <span class="section-title">게임 만들기</span>
  </div>

  <div class="maker-row row2" style="margin-bottom:10px;">
    <div class="card-box">
      <div class="lbl">게임 제목</div>
      <input type="text" id="gameTitle" placeholder="예: 동물 코드네임스" style="width:100%;margin-bottom:10px;">
      <div class="lbl">그리드 크기</div>
      <div style="display:flex;gap:8px;margin-top:4px;">
        <div class="tag" style="cursor:pointer;padding:5px 14px;" onclick="selGrid(4,5)" id="gs45">4×5 (20칸)</div>
        <div class="tag" style="cursor:pointer;padding:5px 14px;background:rgba(92,225,230,0.2);border-color:#5CE1E6;color:#5CE1E6;" onclick="selGrid(5,5)" id="gs55">5×5 (25칸)</div>
        <div class="tag" style="cursor:pointer;padding:5px 14px;" onclick="selGrid(5,6)" id="gs56">5×6 (30칸)</div>
      </div>
    </div>
    <div class="card-box">
      <div class="lbl">제시어(단서) <span class="cnt" id="clueCount">0개</span></div>
      <div style="display:flex;gap:6px;margin-bottom:6px;">
        <input type="text" id="clueInput" placeholder="입력 후 추가 (여러 줄 붙여넣기 가능)" style="flex:1;font-size:13px;" onkeydown="if(event.key==='Enter')addClues()">
        <button class="pri-btn" style="padding:7px 12px;font-size:13px;" onclick="addClues()">추가</button>
      </div>
      <div class="tags-wrap" id="clueList"></div>
    </div>
  </div>

  <div class="maker-row row3" style="margin-bottom:10px;">
    <div class="card-box">
      <div class="lbl" style="color:#4a9eff;">🔵 파랑 (목표) <span class="cnt" id="blueCount">0개</span></div>
      <textarea id="blueInput" rows="3" placeholder="한 줄에 하나씩&#10;붙여넣기 가능"></textarea>
      <button class="pri-btn" style="margin-top:6px;width:100%;padding:7px;font-size:13px;" onclick="addWords('blue')">추가</button>
      <div class="tags-wrap" id="blueList"></div>
    </div>
    <div class="card-box">
      <div class="lbl" style="color:#ff4a4a;">🔴 빨강 (함정) <span class="cnt" id="redCount">0개</span></div>
      <textarea id="redInput" rows="3" placeholder="한 줄에 하나씩&#10;붙여넣기 가능"></textarea>
      <button class="pri-btn" style="margin-top:6px;width:100%;padding:7px;font-size:13px;background:#c0392b;" onclick="addWords('red')">추가</button>
      <div class="tags-wrap" id="redList"></div>
    </div>
    <div class="card-box">
      <div class="lbl" style="color:#aaa;">⬜ 중립 단어 <span class="cnt" id="neutCount">0개</span></div>
      <textarea id="neutInput" rows="3" placeholder="한 줄에 하나씩&#10;붙여넣기 가능&#10;(비워두면 자동 채움)"></textarea>
      <button class="pri-btn" style="margin-top:6px;width:100%;padding:7px;font-size:13px;background:#555;" onclick="addWords('neut')">추가</button>
      <div class="tags-wrap" id="neutList"></div>
    </div>
  </div>

  <div class="action-row">
    <button class="pri-btn" onclick="generateGame()">🎮 게임 생성</button>
    <button class="pri-btn" onclick="shareGame()" style="background:linear-gradient(135deg,#a855f7,#06b6d4);">🔗 공유 코드 생성</button>
    <button class="sec-btn" onclick="saveGame()">💾 저장</button>
    <button class="back-btn" onclick="resetMaker()">🗑 초기화</button>
    <span id="makerMsg" style="font-size:13px;color:#f87171;"></span>
  </div>
  <!-- 공유 코드 표시 -->
  <div id="share-card" style="display:none;margin-top:12px;background:rgba(168,85,247,0.1);border:1px solid rgba(168,85,247,0.4);border-radius:14px;padding:16px 20px;text-align:center;">
    <div style="font-size:13px;color:rgba(255,255,255,0.6);margin-bottom:6px;">학생들에게 이 코드를 알려주세요</div>
    <div id="share-code-display" style="font-size:40px;font-weight:900;color:#a855f7;letter-spacing:8px;font-family:monospace;"></div>
    <div style="font-size:12px;color:rgba(255,255,255,0.4);margin-top:6px;">코드는 24시간 유효합니다</div>
    <button onclick="copyCode()" style="margin-top:10px;background:#a855f7;color:#fff;border:none;border-radius:8px;padding:7px 18px;font-size:13px;font-weight:700;cursor:pointer;">📋 복사</button>
  </div>
</div>

<!-- 플레이 -->
<div class="screen" id="play">
  <div class="play-wrap">
    <div class="play-main">
      <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;">
        <button class="back-btn" onclick="showScreen('home')">← 홈</button>
        <span style="font-size:15px;font-weight:700;color:#5CE1E6;" id="playTitle"></span>
        <button class="back-btn" style="margin-left:auto;" onclick="saveCurrentGame()">💾 저장</button>
      </div>
      <div class="msg-box" id="playMsg">카드를 클릭해서 공개하세요!</div>
      <div class="cards-area"><div class="card-grid" id="cardGrid"></div></div>
    </div>
    <div class="play-side">
      <div class="score-row">
        <div class="sbox b"><div class="snum" id="blueScore">0</div><div class="slbl">파랑 🔵</div></div>
        <div class="sbox r"><div class="snum" id="redScore">0</div><div class="slbl">빨강 🔴</div></div>
      </div>
      <div class="clue-panel">
        <div class="clue-panel-hd">제시어</div>
        <button class="open-btn" id="openClueBtn" onclick="openNextClue()">▶ 제시어 공개</button>
        <div class="clue-list" id="cluePanel"></div>
      </div>
      <div style="display:flex;justify-content:center;padding-top:6px;">
        <img src="data:image/png;base64," style="width:150px;height:auto;opacity:0.7;" alt="Oncuvate">
      </div>
    </div>
  </div>
</div>

<!-- 완료 -->
<div class="screen" id="complete">
  <div style="font-size:64px;" id="cmpIcon">🎉</div>
  <div style="font-size:30px;font-weight:700;color:#5CE1E6;" id="cmpTitle">완료!</div>
  <div style="font-size:15px;color:rgba(255,255,255,0.55);" id="cmpSub"></div>
  <div style="display:flex;gap:12px;">
    <button class="pri-btn" onclick="restartGame()">🔄 다시 하기</button>
    <button class="sec-btn" onclick="showScreen('home')">🏠 홈으로</button>
  </div>
</div>

<!-- 저장된 게임 -->
<div class="screen" id="saved">
  <div style="display:flex;gap:10px;align-items:center;margin-bottom:12px;">
    <button class="back-btn" onclick="showScreen('home')">← 홈</button>
    <span class="section-title">저장된 게임</span>
    <button class="back-btn" style="margin-left:auto;color:#f87171;" onclick="clearAllSaved()">전체 삭제</button>
  </div>
  <div class="saved-grid" id="savedList"></div>
</div>

<script>
var gridRows=5,gridCols=5;
var clues=[],blueWords=[],redWords=[],neutWords=[];
var gameData=null,openedClues=0;

function showScreen(id){
  document.querySelectorAll('.screen').forEach(function(s){s.classList.remove('active');});
  document.getElementById(id).classList.add('active');
  if(id==='saved')renderSavedList();
}

function selGrid(r,c){
  gridRows=r;gridCols=c;
  ['gs45','gs55','gs56'].forEach(function(id){
    var el=document.getElementById(id);
    el.style.background='rgba(92,225,230,0.1)';
    el.style.borderColor='rgba(92,225,230,0.35)';
    el.style.color='#fff';
  });
  var el=document.getElementById('gs'+r+c);
  if(el){el.style.background='rgba(92,225,230,0.2)';el.style.borderColor='#5CE1E6';el.style.color='#5CE1E6';}
}

function parsePaste(val){
  var lines=val.split(String.fromCharCode(10));
  var out=[];
  for(var i=0;i<lines.length;i++){
    var parts=lines[i].split(",");
    for(var j=0;j<parts.length;j++){var w=parts[j].trim();if(w)out.push(w);}
  }
  return out;
}
function addClues(){
  var v=document.getElementById('clueInput').value;
  parsePaste(v).forEach(function(w){if(!clues.includes(w))clues.push(w);});
  document.getElementById('clueInput').value='';
  renderTags('clueList',clues,'clue','');
  document.getElementById('clueCount').textContent=clues.length+'개';
}
function addWords(type){
  var ids={blue:'blueInput',red:'redInput',neut:'neutInput'};
  var arrs={blue:blueWords,red:redWords,neut:neutWords};
  var listIds={blue:'blueList',red:'redList',neut:'neutList'};
  var cntIds={blue:'blueCount',red:'redCount',neut:'neutCount'};
  var tagCls={blue:'',red:'rtag',neut:'ntag'};
  var v=document.getElementById(ids[type]).value;
  parsePaste(v).forEach(function(w){if(!arrs[type].includes(w))arrs[type].push(w);});
  document.getElementById(ids[type]).value='';
  renderTags(listIds[type],arrs[type],type,tagCls[type]);
  document.getElementById(cntIds[type]).textContent=arrs[type].length+'개';
}
function removeItem(type,i){
  var arrs={clue:clues,blue:blueWords,red:redWords,neut:neutWords};
  var listIds={clue:'clueList',blue:'blueList',red:'redList',neut:'neutList'};
  var cntIds={clue:'clueCount',blue:'blueCount',red:'redCount',neut:'neutCount'};
  var tagCls={clue:'',blue:'',red:'rtag',neut:'ntag'};
  arrs[type].splice(i,1);
  renderTags(listIds[type],arrs[type],type,tagCls[type]);
  if(cntIds[type])document.getElementById(cntIds[type]).textContent=arrs[type].length+'개';
}
function renderTags(listId,arr,type,cls){
  var el=document.getElementById(listId);
  el.innerHTML='';
  for(var i=0;i<arr.length;i++){
    var sp=document.createElement('span');
    sp.className='tag '+cls;
    sp.textContent=arr[i];
    var rm=document.createElement('span');
    rm.className='rm';
    rm.textContent='x';
    rm.setAttribute('data-type',type);
    rm.setAttribute('data-idx',i);
    rm.onclick=function(){removeItem(this.getAttribute('data-type'),parseInt(this.getAttribute('data-idx')));};
    sp.appendChild(rm);
    el.appendChild(sp);
  }
}

function resetMaker(){
  clues=[];blueWords=[];redWords=[];neutWords=[];
  ['clueList','blueList','redList','neutList'].forEach(function(id){document.getElementById(id).innerHTML='';});
  ['clueCount','blueCount','redCount','neutCount'].forEach(function(id){document.getElementById(id).textContent='0개';});
  document.getElementById('gameTitle').value='';
  setMakerMsg('');
}
function setMakerMsg(m){document.getElementById('makerMsg').textContent=m;}

function shuffle(arr){
  var a=arr.slice();
  for(var i=a.length-1;i>0;i--){var j=Math.floor(Math.random()*(i+1));var t=a[i];a[i]=a[j];a[j]=t;}
  return a;
}
function buildCards(){
  var total=gridRows*gridCols;
  var pool=[];
  blueWords.forEach(function(w){pool.push({word:w,type:'blue'});});
  redWords.forEach(function(w){pool.push({word:w,type:'red'});});
  neutWords.forEach(function(w){pool.push({word:w,type:'neutral'});});
  pool=shuffle(pool).slice(0,total);
  var need=total-pool.length;
  for(var i=0;i<need;i++)pool.push({word:'?'+(i+1),type:'neutral'});
  return pool.map(function(c){return {word:c.word,type:c.type,revealed:false};});
}

function generateGame(){
  if(!blueWords.length&&!redWords.length){setMakerMsg('단어를 최소 1개 이상 추가하세요.');return;}
  var title=document.getElementById('gameTitle').value.trim()||'코드네임스 게임';
  gameData={
    id:Date.now(),title:title,
    rows:gridRows,cols:gridCols,
    cards:buildCards(),
    clues:clues.slice(),
    blueTotal:blueWords.length,
    redTotal:redWords.length,
    savedAt:new Date().toLocaleDateString('ko-KR')
  };
  setMakerMsg('');
  startPlay(gameData);
}
function saveGame(){
  if(!blueWords.length&&!redWords.length){setMakerMsg('단어를 추가한 후 저장하세요.');return;}
  var title=document.getElementById('gameTitle').value.trim()||'코드네임스 게임';
  var data={
    id:Date.now(),title:title,
    rows:gridRows,cols:gridCols,
    cards:buildCards(),
    clues:clues.slice(),
    blueTotal:blueWords.length,
    redTotal:redWords.length,
    savedAt:new Date().toLocaleDateString('ko-KR')
  };
  var saved=getSaved();saved.push(data);
  localStorage.setItem('cn_games',JSON.stringify(saved));
  setMakerMsg('✓ 저장되었습니다!');
  setTimeout(function(){setMakerMsg('');},2000);
}
function saveCurrentGame(){
  if(!gameData)return;
  var saved=getSaved();
  var idx=-1;
  for(var i=0;i<saved.length;i++){if(saved[i].id===gameData.id){idx=i;break;}}
  gameData.savedAt=new Date().toLocaleDateString('ko-KR');
  if(idx>=0)saved[idx]=gameData;else saved.push(gameData);
  localStorage.setItem('cn_games',JSON.stringify(saved));
  document.getElementById('playMsg').textContent='✓ 저장되었습니다!';
  setTimeout(function(){document.getElementById('playMsg').textContent='카드를 클릭해서 공개하세요!';},1800);
}
function getSaved(){try{return JSON.parse(localStorage.getItem('cn_games')||'[]');}catch(e){return[];}}
function renderSavedList(){
  var saved=getSaved(),el=document.getElementById('savedList');
  if(!saved.length){el.innerHTML='<div class="empty">저장된 게임이 없습니다.</div>';return;}
  el.innerHTML=saved.map(function(g,i){
    return '<div class="sc" onclick="loadSaved('+i+')">'
      +'<div class="sc-title">'+g.title+'</div>'
      +'<div class="sc-meta">'+g.rows+'×'+g.cols+' · 🔵'+g.blueTotal+' 🔴'+g.redTotal+' · 제시어 '+g.clues.length+'개</div>'
      +'<div class="sc-meta" style="margin-top:3px;">저장: '+g.savedAt+'</div>'
      +'</div>';
  }).join('');
}
function loadSaved(i){gameData=getSaved()[i];startPlay(gameData);}
function clearAllSaved(){if(confirm('모두 삭제할까요?')){localStorage.removeItem('cn_games');renderSavedList();}}

function startPlay(data){
  openedClues=0;
  showScreen('play');
  document.getElementById('playTitle').textContent=data.title;
  document.getElementById('playMsg').textContent='카드를 클릭해서 공개하세요!';

  var W=Math.min(120,Math.floor((1280-300)/data.cols)-8);
  var H=Math.min(65,Math.floor((720-180)/data.rows)-8);
  var FS=Math.max(11,Math.min(16,W/5));

  var grid=document.getElementById('cardGrid');
  grid.style.gridTemplateColumns='repeat('+data.cols+','+W+'px)';
  grid.innerHTML=data.cards.map(function(c,i){
    var cls='gc'+(c.revealed?' r-'+c.type:'');
    return '<div class="'+cls+'" id="gc'+i+'" onclick="revealCard('+i+')"'
      +' style="width:'+W+'px;height:'+H+'px;font-size:'+FS+'px;">'+c.word+'</div>';
  }).join('');

  updateScore(data);
  renderClues(data);
}
function revealCard(i){
  if(!gameData||gameData.cards[i].revealed)return;
  gameData.cards[i].revealed=true;
  var c=gameData.cards[i];
  var el=document.getElementById('gc'+i);
  el.className='gc r-'+c.type;
  var msgs={blue:'🔵 파랑 카드! 정답!',red:'🔴 빨강 함정 카드!',neutral:'⬜ 중립 카드.',bomb:'💣 폭탄!'};
  document.getElementById('playMsg').textContent=msgs[c.type]||'공개!';
  updateScore(gameData);
  checkWin(gameData);
}
function updateScore(data){
  var bt=data.blueTotal||data.cards.filter(function(c){return c.type==='blue';}).length;
  var rt=data.redTotal||data.cards.filter(function(c){return c.type==='red';}).length;
  var br=data.cards.filter(function(c){return c.type==='blue'&&c.revealed;}).length;
  var rr=data.cards.filter(function(c){return c.type==='red'&&c.revealed;}).length;
  document.getElementById('blueScore').textContent=br+'/'+bt;
  document.getElementById('redScore').textContent=rr+'/'+rt;
}
function checkWin(data){
  var bLeft=data.cards.filter(function(c){return c.type==='blue'&&!c.revealed;}).length;
  var rLeft=data.cards.filter(function(c){return c.type==='red'&&!c.revealed;}).length;
  if(bLeft===0){
    document.getElementById('cmpIcon').textContent='🎉';
    document.getElementById('cmpTitle').textContent='파랑 팀 승리!';
    document.getElementById('cmpSub').textContent='모든 파랑 카드를 찾았습니다!';
    setTimeout(function(){showScreen('complete');},800);
  } else if(rLeft===0){
    document.getElementById('cmpIcon').textContent='🚨';
    document.getElementById('cmpTitle').textContent='빨강 팀 승리!';
    document.getElementById('cmpSub').textContent='함정 카드가 모두 공개되었습니다!';
    setTimeout(function(){showScreen('complete');},800);
  }
}
function restartGame(){
  if(!gameData)return;
  gameData.cards.forEach(function(c){c.revealed=false;});
  startPlay(gameData);
}
function renderClues(data){
  var panel=document.getElementById('cluePanel');
  panel.innerHTML=(data.clues||[]).map(function(c,i){
    var op=(i<openedClues);
    return '<div class="ci'+(op?' opened':' locked')+'" id="ci'+i+'">'
      +'<div class="cw">'+(op?c:'???')+'</div>'
      +'<div class="cn">#'+(i+1)+(op?' 공개됨':' 잠김')+'</div>'
      +'</div>';
  }).join('');
  var btn=document.getElementById('openClueBtn');
  var rem=(data.clues||[]).length-openedClues;
  btn.disabled=(rem<=0);
  btn.textContent=rem>0?'▶ 다음 제시어 공개 ('+rem+'개 남음)':'모든 제시어 공개됨';
}
function openNextClue(){
  if(!gameData)return;
  if(openedClues>=(gameData.clues||[]).length)return;
  openedClues++;
  renderClues(gameData);
  var el=document.getElementById('ci'+(openedClues-1));
  if(el)el.scrollIntoView({behavior:'smooth',block:'nearest'});
}
</script>

<script>
// ── Firebase 코드네임스 기능 ──

// 6자리 랜덤 코드 생성
function genCode(){
  var chars='ABCDEFGHJKLMNPQRSTUVWXYZ23456789';
  var code='';
  for(var i=0;i<6;i++) code+=chars[Math.floor(Math.random()*chars.length)];
  return code;
}

var currentShareCode = null;

// 게임 공유 코드 생성 + Firebase 저장
function shareGame(){
  if(!blueWords.length&&!redWords.length){
    alert('단어를 먼저 추가하세요.');return;
  }
  var title=document.getElementById('gameTitle').value.trim()||'코드네임스 게임';
  var code=genCode();
  currentShareCode=code;

  // 게임 데이터 생성
  var data={
    title:title,
    rows:gridRows,cols:gridCols,
    cards:buildCards(),
    clues:clues.slice(),
    blueTotal:blueWords.length,
    redTotal:redWords.length,
    createdAt:Date.now(),
    openedClues:0
  };

  // Firebase에 저장 (24시간 후 자동 삭제용 timestamp 포함)
  db.ref('games/'+code).set(data).then(function(){
    document.getElementById('share-card').style.display='block';
    document.getElementById('share-code-display').textContent=code;
    document.getElementById('makerMsg').style.color='#5CE1E6';
    document.getElementById('makerMsg').textContent='✓ Firebase에 저장되었습니다!';
    setTimeout(function(){document.getElementById('makerMsg').textContent='';},3000);
  }).catch(function(err){
    document.getElementById('makerMsg').style.color='#f87171';
    document.getElementById('makerMsg').textContent='Firebase 오류: '+err.message;
  });
}

function copyCode(){
  if(!currentShareCode)return;
  navigator.clipboard.writeText(currentShareCode).then(function(){
    var btn=event.target;
    btn.textContent='✅ 복사됨!';
    setTimeout(function(){btn.textContent='📋 복사';},2000);
  });
}

// 카드 공개 시 Firebase 업데이트 (원본 revealCard 오버라이드)
var _origRevealCard=window.revealCard;
window.revealCard=function(i){
  _origRevealCard(i);
  if(gameData&&gameData.id&&db){
    var update={};
    update['games/'+gameData.id+'/cards/'+i+'/revealed']=true;
    db.ref().update(update);
  }
};

// 제시어 오픈 시 Firebase 업데이트
var _origOpenNextClue=window.openNextClue;
window.openNextClue=function(){
  _origOpenNextClue();
  if(gameData&&gameData.id&&db){
    db.ref('games/'+gameData.id+'/openedClues').set(openedClues);
  }
};

// 페이지 제목 업데이트
document.title='코드네임스 - Oncuvate | hi3957348-boop.github.io';
</script>
